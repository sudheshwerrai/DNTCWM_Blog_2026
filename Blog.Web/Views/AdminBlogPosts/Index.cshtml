@model IEnumerable<Blog.Web.Models.Domain.BlogPost>
@using System.Linq

@{
    ViewData["Title"] = "Blog Posts";
}

<h1>Blog Posts</h1>

<p>
    <a class="btn btn-success" asp-controller="AdminBlogPosts" asp-action="Create">Create New</a>
</p>

<div class="table-responsive">
    <table class="table table-striped table-bordered align-middle">
        <thead class="table-light">
            <tr>
                <th>Heading</th>
                <th>Author</th>
                <th>Published</th>
                <th>Visible</th>
                <th>Tags</th>
                <th style="width:220px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model == null || !Model.Any())
            {
                <tr>
                    <td colspan="6" class="text-center text-muted">No blog posts found.</td>
                </tr>
            }
            else
            {
                foreach (var post in Model)
                {
                    <tr>
                        <td>@post.Heading</td>
                        <td>@post.Author</td>
                        <td>@post.PublishedDate.ToString("MMM d, yyyy HH:mm")</td>
                        <td>
                            @if (post.Visible)
                            {
                                <span class="badge bg-success">Yes</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">No</span>
                            }
                        </td>
                        <td>
                            @{
                                var tags = post.Tags?.Select(t => string.IsNullOrWhiteSpace(t.DisplayName) ? t.Name : t.DisplayName).ToArray() ?? Array.Empty<string>();
                            }
                            @if (tags.Any())
                            {
                                @string.Join(", ", tags)
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>                            
                            <a class="btn btn-sm btn-warning text-white" asp-controller="AdminBlogPosts" asp-action="Edit" asp-route-id="@post.Id">Edit</a>
                            <form asp-controller="AdminBlogPosts" asp-action="Delete" asp-route-id="@post.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure you want to delete this blog post?');">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>