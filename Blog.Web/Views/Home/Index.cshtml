@model IEnumerable<BlogPost>
@using System.Linq

@{
    ViewData["Title"] = "Home Page";
}

<div class="pb-3">
    <h1 class="mb-3">Latest Posts</h1>
</div>

@if (Model == null || !Model.Any())
{
    <div class="text-center text-muted">No blog posts available.</div>
}
else
{
    <div class="row g-4">
        @foreach (var post in Model)
        {
            <div class="col-12 col-sm-6 col-md-4">
                <div class="card h-100 shadow-sm">
                    @if (!string.IsNullOrWhiteSpace(post.FeaturedImageUrl))
                    {
                        <img src="@post.FeaturedImageUrl" class="card-img-top" alt="@post.Heading" style="object-fit:cover; height:180px;" />
                    }
                    else
                    {
                        <div class="bg-light d-flex align-items-center justify-content-center" style="height:180px;">
                            <span class="text-muted">No image</span>
                        </div>
                    }

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@post.Heading</h5>
                        <p class="card-text text-muted small mb-2">By @post.Author on @post.PublishedDate.ToString("MMM d, yyyy")</p>
                        <p class="card-text">@(!string.IsNullOrWhiteSpace(post.ShortDescription) ? (post.ShortDescription.Length > 150 ? post.ShortDescription.Substring(0, 150) + "..." : post.ShortDescription) : "")</p>
                        <div class="mt-auto">
                            <a class="btn btn-sm btn-primary" asp-controller="Blogs" asp-action="BlogPostDetail" asp-route-urlHandle="@post.UrlHandle">Read more</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
